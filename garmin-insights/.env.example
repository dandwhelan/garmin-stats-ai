# InfluxDB (local)
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8086
INFLUXDB_DATABASE=GarminStats
INFLUXDB_USERNAME=
INFLUXDB_PASSWORD=

# MariaDB (Pi5 Docker)
MARIADB_HOST=192.168.1.x
MARIADB_PORT=3306
MARIADB_USER=garmin_insights
MARIADB_PASSWORD=changeme
MARIADB_DATABASE=garmin_insights

# Google Gemini
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Scheduler — comma-separated HH:MM times for daily scans
SCAN_TIMES=06:00,12:00,18:00,22:00
