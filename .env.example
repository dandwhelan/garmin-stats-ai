# Single-user .env template. Copy to `.env` at the repo root and fill in.
# For multi-user mode, use users/<name>.env files instead (see users/*.env.example).

# ─── Garmin Connect ───────────────────────────────────────────────────────────
GARMINCONNECT_EMAIL=your@email.com
GARMINCONNECT_PASSWORD=your_password

# Absolute path to the SQLite DB shared between the fetcher and the web app.
SQLITE_DB_PATH=/home/you/garmin-stats-ai/garmin.db

# Where to cache the OAuth token after the first login (optional).
TOKEN_DIR=/home/you/.garminconnect

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Default is claude-sonnet-4-6. Set to claude-opus-4-8 for deeper reasoning
# (~5× the cost per call).
# CLAUDE_MODEL=claude-sonnet-4-6

# ─── Web server ───────────────────────────────────────────────────────────────
# Bind to 127.0.0.1 for localhost-only. Use 0.0.0.0 only if you understand the
# Security section of the README — this app has no auth.
WEB_HOST=127.0.0.1
WEB_PORT=8080

# ─── UI identity ──────────────────────────────────────────────────────────────
DISPLAY_NAME=Alice
BIOLOGICAL_SEX=Female   # Male / Female — drives sex-specific reference ranges
                        # and (Female) menstrual-phase context in the AI prompt
