# Per-user fetcher config for "bob"
# Copy this file to bob.env and fill in real values.
# Never commit the real .env files — they contain credentials.

GARMINCONNECT_EMAIL=bob@example.com
GARMINCONNECT_PASSWORD=his_garmin_password

# Each user MUST have a separate DB file and a separate token directory.
SQLITE_DB_PATH=/home/pi/garmin-data/bob.db
TOKEN_DIR=/home/pi/.garminconnect-bob

# Optional — leave defaults unless you need to change them
# UPDATE_INTERVAL_SECONDS=300
# FETCH_SELECTION=daily_avg,sleep,steps,heartrate,stress,breathing,hrv,fitness_age,vo2,activity,race_prediction,body_composition,lifestyle
# LOG_LEVEL=INFO
