# Per-user fetcher config for "alice"
# Copy this file to alice.env and fill in real values.
# Never commit the real .env files — they contain credentials.

GARMINCONNECT_EMAIL=alice@example.com
GARMINCONNECT_PASSWORD=her_garmin_password

# Each user MUST have a separate DB file and a separate token directory.
SQLITE_DB_PATH=/home/pi/garmin-data/alice.db
TOKEN_DIR=/home/pi/.garminconnect-alice

# Home location for the Open-Meteo weather / air-quality / pollen pipeline.
# Leave both unset to skip environmental data entirely.
# HOME_LAT=51.5074
# HOME_LON=-0.1278

# Optional — leave defaults unless you need to change them
# UPDATE_INTERVAL_SECONDS=300
# FETCH_SELECTION=daily_avg,sleep,steps,heartrate,stress,breathing,hrv,fitness_age,vo2,activity,race_prediction,body_composition,lifestyle,environment
# ENVIRONMENT_PAST_DAYS=92
# LOG_LEVEL=INFO
